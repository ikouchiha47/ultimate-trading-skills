# Copy to .env (gitignored) and edit. All host/secret/endpoint/model settings live here and are
# read through framework/config.py (load via ensure_env()). Do NOT hardcode these in code.

# --- Local models (Ollama) — optional, for the technical-analyst vision fallback -----------
# Config-gated: the vision fallback only runs when LOCAL_VISION_ENABLED=true.
LOCAL_VISION_ENABLED=true
OLLAMA_ENDPOINT=http://localhost:11434
VISION_MODEL=qwen2.5vl:3b                 # validated for chart number-OCR + colour reading
VISION_DATA_POLICY=image-only             # ONLY the chart image + prompt may leave the machine
VISION_MAX_IMAGE_PX=1536                  # Pillow downscales larger images before sending

# --- OpenAlgo (live/execution layer — deferred; only needed for forward-test/trade) --------
# OPENALGO_API_KEY=
# OPENALGO_HOST=http://127.0.0.1:5000

# --- screener.in fundamentals (Playwright) -------------------------------------------------
# Optional: path to a saved screener session (default ~/.screener_session.json).
# SCREENER_SESSION=/Users/you/.screener_session.json
